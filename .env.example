# Required — Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# Required — Create a bot via @BotFather on Telegram: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here

# Required — Your Telegram numeric user ID (get it from @userinfobot: https://t.me/userinfobot)
# Comma-separated for multiple users: 123,456,789
TELEGRAM_ALLOW_FROM=123456789

# Optional — Model to use (default: openrouter/x-ai/grok-3-fast)
OPENCLAW_MODEL=openrouter/x-ai/grok-3-fast

# Optional — Timezone (default: UTC)
TZ=UTC
